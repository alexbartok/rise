  "notes": [
    {
      "title": "Flour",
      "content": "Caputo Nuvola Super (W 260-280): Lighter, more open crumb. First choice.\nCaputo Pizzeria (W 260-270): Tighter dough, more classic texture. More affordable alternative, interchangeable 1:1.\nAdjust hydration by feel while kneading."
    },
    {
      "title": "Yeast and salt",
      "content": "Yeast is always incorporated first; salt water is added gradually afterwards. Salt inhibits yeast on direct contact."
    },
    {
      "title": "Hydration",
      "content": "Total hydration 65% (650 ml water per 1 kg flour)."
    }
  ]
